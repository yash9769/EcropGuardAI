# ============================================================
# eCropGuard AI — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file.
# ============================================================

# ---- Frontend (Vite) ----
# Supabase project URL and anon key (exposed to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API base URL (leave empty to use Vite proxy in dev)
# In production: set this to your deployed backend URL, e.g. https://api.yourapp.com
VITE_API_URL=

# ---- Backend (FastAPI) ----
# Groq API key — required for multi-model LLM chat
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key — required for disease detection (vision)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — required for RAG vector search and database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here
SUPABASE_RAG_URL=https://your-project.supabase.co/functions/v1/rag-query

# Supabase service role key — backend-only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---- Optional ----
LOG_LEVEL=INFO
