# ================================================================
# eCropGuard AI — Backend Environment Variables
# Copy this file to backend/.env and fill in the values.
# NEVER commit your actual .env file.
# ================================================================

# Required — Groq API key for multi-model LLM inference
GROQ_API_KEY=your_groq_api_key_here

# Required — Gemini API key for disease detection (vision model)
GEMINI_API_KEY=your_gemini_api_key_here

# Required — Supabase for RAG vector search
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here
SUPABASE_RAG_URL=https://your-project.supabase.co/functions/v1/rag-query

# Optional
LOG_LEVEL=INFO
