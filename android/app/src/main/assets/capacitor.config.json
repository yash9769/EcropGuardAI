{
	"appId": "com.agrisense.app",
	"appName": "AgriSense",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"Camera": {
			"permissions": [
				"camera",
				"photos"
			]
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	}
}
